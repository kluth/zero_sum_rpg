{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": false // Only the backend can assign roles or create users
      }
    },
    "sessions": {
      "$session_id": {
        // Removed global .read: "auth != null" to prevent Darknet E2EE bypass!
        ".write": false,
        
        "darknet": {
          "$channel_id": {
            // E2EE Channels: Only members of the channel can read.
            ".read": "auth != null && $channel_id.contains(auth.uid)",
            "$message_id": {
              // Only members can write, and they can only append their own messages
              ".write": "auth != null && $channel_id.contains(auth.uid) && !data.exists()",
              ".validate": "newData.hasChildren(['sender', 'ciphertext', 'nonce', 'timestamp']) && newData.child('sender').val() === auth.uid"
            }
          }
        },

        "clocks": {
          ".read": "auth != null",
          // Progress Clocks: Only GM or Backend can mutate
          ".write": "auth != null && root.child('users/'+auth.uid+'/isGM').val() === true"
        },

        "gameState": {
          ".read": "auth != null",
          // CORE LOCKDOWN: The GameState is strictly read-only for players.
          ".write": "auth != null && root.child('users/'+auth.uid+'/isGM').val() === true",
          
          "narrativeContext": {
            ".write": "auth != null && root.child('users/'+auth.uid+'/isGM').val() === true"
          }
        },

        "actionQueue": {
          ".read": "auth != null",
          // PLAYERS WRITE HERE: Players submit ActionDTOs. GMs can delete them.
          "$action_id": {
            ".write": "(auth != null && !data.exists() && newData.child('playerId').val() === auth.uid) || (auth != null && root.child('users/'+auth.uid+'/isGM').val() === true)",
            ".validate": "!newData.exists() || newData.hasChildren(['type', 'apCost'])"
          }
        }
      }
    }
  }
}
