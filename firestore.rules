rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /community_sessions/{sessionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.gmId == request.auth.uid;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
